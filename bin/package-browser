#!/bin/bash -e

ROOT=`dirname $0`

cd "$ROOT/.."

# Skip translation update if locale is already in repo (no .git directory)
if [ -d packages/desktop-client/locale/.git ]; then
    echo "Updating translations..."
    pushd packages/desktop-client/locale > /dev/null
    git checkout .
    git pull
    popd > /dev/null
    packages/desktop-client/bin/remove-untranslated-languages
elif [ -d packages/desktop-client/locale ]; then
    echo "Translations already bundled in repo, skipping update"
else
    echo "Cloning translations..."
    git clone https://github.com/actualbudget/translations packages/desktop-client/locale
    packages/desktop-client/bin/remove-untranslated-languages
fi

export NODE_OPTIONS="--max-old-space-size=4096"

yarn workspace plugins-service build
yarn workspace loot-core build:browser
yarn workspace @actual-app/web build:browser

echo "packages/desktop-client/build"
